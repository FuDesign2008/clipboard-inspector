{
	"name": "clipboard-inspector",
	"version": "1.0.0",
	"license": "MIT",
	"scripts": {
		"prepare": "git config core.hooksPath .git-hooks",
		"start": "esbuild src/index.tsx --outfile=index.js --bundle --servedir=.",
		"typecheck": "tsc --noEmit",
		"typecheck:watch": "tsc --noEmit --watch",
		"build": "npm run typecheck && esbuild src/index.tsx --outfile=index.js --bundle '--define:process.env.NODE_ENV=\"production\"' --banner:js='// This file is auto-generated from src/, do not edit directly.'",
		"deploy": "npm run build && gh-pages -d ."
	},
	"devDependencies": {
		"@types/react": "^18.3.28",
		"@types/react-dom": "^18.3.7",
		"esbuild": "^0.17.4",
		"gh-pages": "^5.0.0",
		"prettier": "^2.8.3",
		"pretty-quick": "^3.1.3",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"jszip": "^3.10.1",
		"react": "^18.2.0",
		"react-dom": "^18.2.0"
	},
	"prettier": {
		"bracketSpacing": true,
		"semi": true,
		"singleQuote": true,
		"trailingComma": "none",
		"useTabs": true,
		"tabWidth": 4,
		"jsxBracketSameLine": false,
		"arrowParens": "avoid",
		"printWidth": 80
	}
}
