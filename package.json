{
	"name": "clipboard-inspector",
	"version": "1.0.0",
	"license": "MIT",
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"prepare": "git config core.hooksPath .git-hooks",
		"start": "esbuild src/index.tsx --outfile=index.js --bundle --servedir=.",
		"typecheck": "tsc --noEmit",
		"typecheck:watch": "tsc --noEmit --watch",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"test": "vitest",
		"test:run": "vitest run",
		"test:watch": "vitest",
		"build": "npm run typecheck && npm run lint && esbuild src/index.tsx --outfile=index.js --bundle '--define:process.env.NODE_ENV=\"production\"' --banner:js='// This file is auto-generated from src/, do not edit directly.'"
	},
	"devDependencies": {
		"@eslint/js": "^9.18.0",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"esbuild": "^0.28.0",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-react": "^7.37.4",
		"eslint-plugin-react-hooks": "^5.1.0",
		"globals": "^15.14.0",
		"lint-staged": "^16.4.0",
		"prettier": "^3.8.3",
		"pretty-quick": "^4.2.2",
		"typescript": "^5.9.0",
		"typescript-eslint": "^8.20.0",
		"vitest": "^3.0.0"
	},
	"dependencies": {
		"jszip": "^3.10.1",
		"react": "^18.3.1",
		"react-dom": "^18.3.1"
	},
	"prettier": {
		"bracketSpacing": true,
		"semi": true,
		"singleQuote": true,
		"trailingComma": "none",
		"useTabs": true,
		"tabWidth": 4,
		"bracketSameLine": false,
		"arrowParens": "avoid",
		"printWidth": 80
	},
	"lint-staged": {
		"src/**/*.{ts,tsx}": [
			"eslint --fix --no-warn-ignored",
			"prettier --write"
		],
		"*.{js,mjs,cjs,json,md,yml,yaml,html,css}": [
			"prettier --write --ignore-unknown"
		]
	}
}
